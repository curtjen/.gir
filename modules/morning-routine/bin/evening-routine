#!/bin/bash
set -euo pipefail

resolve_script_dir() {
  local source="${BASH_SOURCE[0]}"
  while [[ -L "$source" ]]; do
    local dir
    dir="$(cd -P "$(dirname "$source")" && pwd)"
    source="$(readlink "$source")"
    [[ "$source" != /* ]] && source="$dir/$source"
  done
  cd -P "$(dirname "$source")" && pwd
}

SCRIPT_DIR="$(resolve_script_dir)"
HELPER="$SCRIPT_DIR/routine-config-helper.js"
CONFIG_PATH="${MORNING_ROUTINE_CONFIG:-$HOME/.morning-routine.json}"

log() {
  printf '[evening-routine] %s\n' "$1"
}

warn() {
  printf '[evening-routine] WARN: %s\n' "$1"
}

helper() {
  node "$HELPER" "$@"
}

main() {
  if ! command -v node >/dev/null 2>&1; then
    warn "node is required to update $CONFIG_PATH"
    exit 1
  fi

  if [[ ! -f "$HELPER" ]]; then
    warn "Helper not found at $HELPER"
    exit 1
  fi

  if [[ ! -f "$CONFIG_PATH" ]]; then
    warn "Config file not found at $CONFIG_PATH"
    exit 1
  fi

  if [[ "${1:-}" == "--clear" ]]; then
    helper clear-in-progress "$CONFIG_PATH"
    log "Cleared in-progress state"
    return
  fi

  if [[ "${1:-}" == "--show" ]]; then
    log "In progress: $(helper state-field "$CONFIG_PATH" in_progress)"
    return
  fi

  local message="${*:-}"

  if [[ -z "$message" ]]; then
    printf 'What is still in progress for tomorrow? '
    IFS= read -r message
  fi

  helper set-in-progress "$CONFIG_PATH" "$message"
  log "Updated in-progress state"
}

main "$@"
